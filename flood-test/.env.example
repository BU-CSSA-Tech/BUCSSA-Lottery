# 复制为 .env 后填入真实值
# cp .env.example .env

# ── 压测目标 ──────────────────────────────────────────────
WS_TARGET=ws://localhost:4000
HTTP_TARGET=http://localhost:4000

# ── JWT（须与 frontend/backend 的 JWT_SECRET 保持一致）────
JWT_SECRET=your-jwt-secret-here

# ── Redis（部分脚本需要）──────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── E2E 全流程压测（e2e-code-game-load-test.js，可选）────
# E2E_API_BASE=http://localhost:4000
# E2E_WS_TARGET=ws://localhost:4000
# E2E_LOGIN_CODE=123456
# E2E_USERS=200
# E2E_ARRIVAL_RATE=20
# E2E_DURATION=180

# ── 验证码登录压测（code-login-test.js，可选）──────────────
# CODE_LOGIN_TEST_TARGET=http://localhost:4000
# CODE_LOGIN_TEST_CODE=123456
# CODE_LOGIN_TEST_DURATION=30
# CODE_LOGIN_TEST_ARRIVAL_RATE=100
