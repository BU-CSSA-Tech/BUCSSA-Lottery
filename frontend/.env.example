# 复制为 .env.local 后填入真实值
# cp .env.example .env.local

# ── 公开配置（会暴露到浏览器）──────────────────────────────
NEXT_PUBLIC_API_BASE=http://localhost:4000
NEXT_PUBLIC_THEME=mario

# ── NextAuth ──────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-nextauth-secret-here

# ── Google OAuth ──────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── Azure AD OAuth ────────────────────────────────────────
AZURE_AD_CLIENT_ID=your-azure-ad-client-id
AZURE_AD_CLIENT_SECRET=your-azure-ad-client-secret
AZURE_AD_TENANT_ID=common

# ── JWT（须与 backend/.env 中的 JWT_SECRET 保持一致）──────
JWT_SECRET=your-jwt-secret-here

# ── 数据库（快照/Prisma 用，须与 backend/.env 保持一致）──
DATABASE_URL="postgresql://user:password@host:5432/database"

# ── 工作人员密码登录（Credentials Provider）──────────────
STAFF_ADMIN_PASSWORD=your-admin-password
STAFF_DISPLAY_PASSWORD=your-display-password
